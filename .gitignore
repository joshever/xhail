# ---------------------------------------------------------------------------
xhail/output/
xhail_output/
# Experiment results (generated data — keep directory, ignore content)
experiments/results/*.csv
experiments/results/*.json
experiments/results/figures/

# ---------------------------------------------------------------------------
# Repo-specific scratch files (not deleted due to filesystem constraints)
# ---------------------------------------------------------------------------
hey.lp
play/


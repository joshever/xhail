__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
.venv/
venv/
env/

# ---------------------------------------------------------------------------
# Type checking / linting
# ---------------------------------------------------------------------------
.mypy_cache/
.ruff_cache/

